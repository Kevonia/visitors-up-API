# ============================================================================
# Twickenham Glades API — environment variables
# Copy to `.env` and fill in real values. NEVER commit your real .env.
# In production set these via your deployment environment / secrets manager.
# ============================================================================

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vistorsapp
POSTGRES_HOST=localhost          # docker-compose overrides this to "db"
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---------------------------------------------------------------------------
# Redis (caching, token blacklist, rate limiting)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0   # docker-compose overrides host to "redis"

# ---------------------------------------------------------------------------
# JWT / Auth
# ---------------------------------------------------------------------------
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Login rate limiting / abuse protection
FAILED_LOGIN_RETENTION_DAYS=30
MAX_USER_ATTEMPTS=5
MAX_IP_ATTEMPTS=20

# ---------------------------------------------------------------------------
# PII encryption at rest
# Secret used to derive the AES key for encrypted PII columns. Must be strong
# and STABLE — changing it makes existing encrypted data unreadable.
# ---------------------------------------------------------------------------
PII_ENCRYPTION_KEY=change-me-to-a-strong-stable-secret

# ---------------------------------------------------------------------------
# Zoho Invoice integration
# ---------------------------------------------------------------------------
CLIENT_ID=your-zoho-client-id
CLIENT_SECRET=your-zoho-client-secret
REFRESH_TOKEN=your-zoho-refresh-token
ACCESS_TOKEN=your-zoho-access-token
ZOHO_API_URL=https://www.zohoapis.com/invoice/v3
ZOHO_ORG_ID=your-zoho-organization-id

# Resident payment-list / Zoho caching
RED_BALANCE_THRESHOLD=18000     # RED if not on a plan and outstanding > this
ZOHO_CACHE_TTL=21600            # seconds a resident's cached Zoho data stays fresh
GATE_BLOCK_DELINQUENT=true      # block checking in a RED resident's visitor

# ---------------------------------------------------------------------------
# Accounting provider — which back-end issues invoices/dues (Zoho today).
# "zoho" (default) or "quickbooks".
# ---------------------------------------------------------------------------
ACCOUNTING_PROVIDER=zoho

# ---------------------------------------------------------------------------
# In-app payments (WiPay / DimePay). OFF until a provider's keys are set.
# PAYMENTS_PROVIDERS is a CSV of enabled providers: wipay,dimepay,test
# PAYMENT_RETURN_BASE_URL is where providers redirect after checkout, e.g.
#   https://vms-api.onrender.com/api/v1/payments/return
# ---------------------------------------------------------------------------
PAYMENTS_ENABLED=false
PAYMENTS_PROVIDERS=
DEFAULT_PAYMENT_PROVIDER=
PAYMENT_RETURN_BASE_URL=
PLATFORM_FEE_PCT=0
PAYMENT_PENDING_GRACE_MINUTES=20

# WiPay Jamaica (hosted redirect checkout)
WIPAY_ENV=sandbox               # sandbox | live
WIPAY_BASE_URL=https://jm.wipayfinancial.com
WIPAY_ACCOUNT_NUMBER=           # your WiPay business key / account number
WIPAY_API_KEY=                  # used to validate the response hash
WIPAY_COUNTRY=JM

# DimePay (REST API; client_key auth; no webhooks → return + poll)
DIMEPAY_ENV=sandbox             # sandbox | live
DIMEPAY_BASE_URL=https://sandbox.api.dimepay.app/dapi/v1
DIMEPAY_CLIENT_KEY=

# ---------------------------------------------------------------------------
# Bootstrap accounts (created on deploy by scripts/seed_prod.py)
# Override the passwords (and ideally emails/phones) in production.
# ---------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_PHONE=10000000000
SECURITY_EMAIL=security@example.com
SECURITY_PASSWORD=change-me
SECURITY_PHONE=10000000001

# ---------------------------------------------------------------------------
# Resident notifications (email + SMS)
# NOTIFICATIONS_TRANSPORT: "brevo" (production, via Brevo API) or
#   "smtp" (dev, via the local Mailpit catcher at http://localhost:8025).
# ---------------------------------------------------------------------------
PUBLIC_BASE_URL=http://localhost:8001
NOTIFICATIONS_ENABLED=false
NOTIFICATIONS_TRANSPORT=brevo
SMTP_HOST=mailpit
SMTP_PORT=1025
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=no-reply@twickenhamglades.com
BREVO_SENDER_NAME=Twickenham Glades
BREVO_SMS_SENDER=TwickGlades

# ---------------------------------------------------------------------------
# Local/dev flags
# DEV_SKIP_ZOHO=true bypasses Zoho contact/address checks (signup + /users/me)
# and serves demo data. MUST be false in production.
# ---------------------------------------------------------------------------
DEV_SKIP_ZOHO=false

# ---------------------------------------------------------------------------
# Runtime / Docker
# Host port the API is published on by docker-compose (container stays 8000).
# ---------------------------------------------------------------------------
API_PORT=8001

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
