# ============================================================================
# Twickenham Glades API — environment variables
# Copy to `.env` and fill in real values. NEVER commit your real .env.
# In production set these via your deployment environment / secrets manager.
# ============================================================================

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vistorsapp
POSTGRES_HOST=localhost          # docker-compose overrides this to "db"
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---------------------------------------------------------------------------
# Redis (caching, token blacklist, rate limiting)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0   # docker-compose overrides host to "redis"

# ---------------------------------------------------------------------------
# JWT / Auth
# ---------------------------------------------------------------------------
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Login rate limiting / abuse protection
FAILED_LOGIN_RETENTION_DAYS=30
MAX_USER_ATTEMPTS=5
MAX_IP_ATTEMPTS=20

# ---------------------------------------------------------------------------
# PII encryption at rest
# Secret used to derive the AES key for encrypted PII columns. Must be strong
# and STABLE — changing it makes existing encrypted data unreadable.
# ---------------------------------------------------------------------------
PII_ENCRYPTION_KEY=change-me-to-a-strong-stable-secret

# ---------------------------------------------------------------------------
# Zoho Invoice integration
# ---------------------------------------------------------------------------
CLIENT_ID=your-zoho-client-id
CLIENT_SECRET=your-zoho-client-secret
REFRESH_TOKEN=your-zoho-refresh-token
ACCESS_TOKEN=your-zoho-access-token
ZOHO_API_URL=https://invoice.zoho.com/api/v3

# ---------------------------------------------------------------------------
# Bootstrap accounts (created on deploy by scripts/seed_prod.py)
# Override the passwords (and ideally emails/phones) in production.
# ---------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_PHONE=10000000000
SECURITY_EMAIL=security@example.com
SECURITY_PASSWORD=change-me
SECURITY_PHONE=10000000001

# ---------------------------------------------------------------------------
# Local/dev flags
# DEV_SKIP_ZOHO=true bypasses Zoho contact/address checks (signup + /users/me)
# and serves demo data. MUST be false in production.
# ---------------------------------------------------------------------------
DEV_SKIP_ZOHO=false

# ---------------------------------------------------------------------------
# Runtime / Docker
# Host port the API is published on by docker-compose (container stays 8000).
# ---------------------------------------------------------------------------
API_PORT=8001
